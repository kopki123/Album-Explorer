{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"],
      "@/*": ["./app/*"]
    },
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "lib": [
      "ESNext",
      "dom",
      "dom.iterable",
      "webworker"
    ]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.vue",
    "app/**/*.d.ts",

    "types/**/*.ts",
    "types/**/*.d.ts",

    "env.d.ts",
    "nuxt.config.ts",
    ".nuxt/**/*.ts"
  ],
  "exclude": [
    "dist",
    ".output",
    "out-tsc",
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "app/**/*.test.ts",
    "app/**/*.spec.ts",
    "app/**/*.test.tsx",
    "app/**/*.spec.tsx",
    "app/**/*.test.js",
    "app/**/*.spec.js",
    "app/**/*.test.jsx",
    "app/**/*.spec.jsx",
    "server/**/*.test.ts",
    "server/**/*.spec.ts",
    "server/**/*.test.tsx",
    "server/**/*.spec.tsx",
    "server/**/*.test.js",
    "server/**/*.spec.js",
    "server/**/*.test.jsx",
    "server/**/*.spec.jsx",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ]
}
